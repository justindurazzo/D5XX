# Resend API key — get yours free at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The email address where RSVP submissions will be sent
RSVP_TO_EMAIL=your@email.com

# The "from" address — must be a domain you've verified in Resend
# For testing you can use: onboarding@resend.dev
RSVP_FROM_EMAIL=d5xx@droga5.com

# ───── Google Sheet RSVP log (optional — see NOTES.md for full setup) ─────
# The spreadsheet ID from its URL:
#   docs.google.com/spreadsheets/d/<THIS_IS_THE_ID>/edit
RSVP_SHEET_ID=

# The full Google service-account JSON key, collapsed onto a single line.
# Grant this service account's email Editor access to the sheet above.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
